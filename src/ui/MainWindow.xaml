<Window x:Class="CatCalculate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐱 CatCalculate"
        Width="360"
        Height="660"
        MinWidth="320"
        MinHeight="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!--
        Root Grid contains two layers:
          1. The main rounded window body (offset down to expose the ears above it)
          2. An overlay Canvas that draws the cat ears on top of / above the body
    -->
    <Grid>

        <!-- =============================================================
             LAYER 1 – Main window body
             Margin top = 38 leaves room for the cat ears above.
             ============================================================= -->
        <Border Background="{StaticResource WindowBackgroundBrush}"
                CornerRadius="24"
                BorderThickness="1.5"
                BorderBrush="{StaticResource CatWhiskerBrush}"
                Margin="0,38,0,0"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="6"
                                  Direction="270" Color="#80806090" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Title bar -->
                    <RowDefinition Height="50"/>
                    <!-- Display area -->
                    <RowDefinition Height="100"/>
                    <!-- Thin separator -->
                    <RowDefinition Height="10"/>
                    <!-- Button grid -->
                    <RowDefinition Height="*"/>
                    <!-- Paw-print footer -->
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- =====================================================
                     ROW 0 – Title bar
                     ===================================================== -->
                <Border Grid.Row="0"
                        Background="{StaticResource CatLavenderBrush}"
                        CornerRadius="22,22,0,0"
                        Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- App title -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="🐱"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="CatCalculate"
                                       Style="{StaticResource TitleTextStyle}"/>
                        </StackPanel>

                        <!-- Close button -->
                        <Button Grid.Column="1"
                                Content="✕"
                                Width="30" Height="30"
                                Margin="0,0,4,0"
                                FontSize="13"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#9060B0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="15">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource CatPinkBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource CatPinkDarkBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- =====================================================
                     ROW 1 – Display area
                     ===================================================== -->
                <Border Grid.Row="1"
                        Background="{StaticResource DisplayGradientBrush}"
                        CornerRadius="14"
                        Margin="14,6,14,4"
                        Padding="16,8"
                        Effect="{StaticResource DisplayShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Expression / history line -->
                        <TextBlock x:Name="ExpressionDisplay"
                                   Grid.Row="0"
                                   Style="{StaticResource DisplayExpressionStyle}"
                                   Text=""/>

                        <!-- Main result / current input -->
                        <TextBlock x:Name="ResultDisplay"
                                   Grid.Row="1"
                                   Style="{StaticResource DisplayResultStyle}"
                                   Text="0"/>
                    </Grid>
                </Border>

                <!-- =====================================================
                     ROW 2 – Decorative separator
                     ===================================================== -->
                <Rectangle Grid.Row="2"
                           Style="{StaticResource CatSeparatorStyle}"
                           VerticalAlignment="Center"/>

                <!-- =====================================================
                     ROW 3 – Button grid  (6 rows × 4 columns)
                     Layout:
                       Row 0 : [C]    [CE]   [±]    [⌫]
                       Row 1 : [7]    [8]    [9]    [÷]
                       Row 2 : [4]    [5]    [6]    [×]
                       Row 3 : [1]    [2]    [3]    [−]
                       Row 4 : [%]    [0]    [.]    [+]
                       Row 5 : [= (full-width, spans all 4 columns) ]
                     ===================================================== -->
                <Grid Grid.Row="3" Margin="10,4,10,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Row 0: function keys ── -->
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="C"
                            Style="{StaticResource FunctionButtonStyle}"
                            Click="Clear_Click"
                            ToolTip="Clear all"/>

                    <Button Grid.Row="0" Grid.Column="1"
                            Content="CE"
                            Style="{StaticResource FunctionButtonStyle}"
                            Click="ClearEntry_Click"
                            ToolTip="Clear entry"/>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="±"
                            Style="{StaticResource FunctionButtonStyle}"
                            Click="ToggleSign_Click"
                            ToolTip="Toggle sign"/>

                    <Button Grid.Row="0" Grid.Column="3"
                            Content="⌫"
                            Style="{StaticResource FunctionButtonStyle}"
                            Click="Backspace_Click"
                            ToolTip="Backspace"/>

                    <!-- ── Row 1: 7 8 9 ÷ ── -->
                    <Button Grid.Row="1" Grid.Column="0"
                            Content="7"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="1" Grid.Column="1"
                            Content="8"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="1" Grid.Column="2"
                            Content="9"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="1" Grid.Column="3"
                            Content="÷"
                            Tag="÷"
                            Style="{StaticResource OperatorButtonStyle}"
                            Click="Operator_Click"
                            ToolTip="Divide"/>

                    <!-- ── Row 2: 4 5 6 × ── -->
                    <Button Grid.Row="2" Grid.Column="0"
                            Content="4"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="2" Grid.Column="1"
                            Content="5"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="2" Grid.Column="2"
                            Content="6"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="2" Grid.Column="3"
                            Content="×"
                            Tag="×"
                            Style="{StaticResource OperatorButtonStyle}"
                            Click="Operator_Click"
                            ToolTip="Multiply"/>

                    <!-- ── Row 3: 1 2 3 − ── -->
                    <Button Grid.Row="3" Grid.Column="0"
                            Content="1"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="3" Grid.Column="1"
                            Content="2"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="3" Grid.Column="2"
                            Content="3"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="3" Grid.Column="3"
                            Content="−"
                            Tag="−"
                            Style="{StaticResource OperatorButtonStyle}"
                            Click="Operator_Click"
                            ToolTip="Subtract"/>

                    <!-- ── Row 4: % 0 . + ── -->
                    <Button Grid.Row="4" Grid.Column="0"
                            Content="%"
                            Style="{StaticResource FunctionButtonStyle}"
                            Click="Percent_Click"
                            ToolTip="Percent"/>

                    <Button Grid.Row="4" Grid.Column="1"
                            Content="0"
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Digit_Click"/>

                    <Button Grid.Row="4" Grid.Column="2"
                            Content="."
                            Style="{StaticResource NumberButtonStyle}"
                            Click="Decimal_Click"
                            ToolTip="Decimal point"/>

                    <Button Grid.Row="4" Grid.Column="3"
                            Content="+"
                            Tag="+"
                            Style="{StaticResource OperatorButtonStyle}"
                            Click="Operator_Click"
                            ToolTip="Add"/>

                    <!-- ── Row 5: = (full width) ── -->
                    <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                            Content="="
                            Style="{StaticResource EqualsButtonStyle}"
                            Click="Equals_Click"
                            ToolTip="Calculate"/>
                </Grid>

                <!-- =====================================================
                     ROW 4 – Decorative paw-print footer
                     ===================================================== -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Viewbox Width="20" Height="20" Margin="6,0">
                        <Path Data="{StaticResource PawPrintGeometry}"
                              Fill="{StaticResource CatPinkBrush}"
                              Opacity="0.6"/>
                    </Viewbox>

                    <TextBlock Text="🐾"
                               FontSize="13"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="2,0"/>

                    <Viewbox Width="20" Height="20" Margin="6,0">
                        <Path Data="{StaticResource PawPrintGeometry}"
                              Fill="{StaticResource CatLavenderDarkBrush}"
                              Opacity="0.6"/>
                    </Viewbox>
                </StackPanel>

            </Grid>
        </Border><!-- /main body -->

        <!-- =============================================================
             LAYER 2 – Cat ear overlay
             Positioned absolutely in the root Grid so the ears are NOT
             clipped by the main border's CornerRadius.
             IsHitTestVisible=False lets mouse events pass through to the
             window body beneath.
             ============================================================= -->
        <Canvas IsHitTestVisible="False"
                VerticalAlignment="Top">

            <!-- Left ear -->
            <!-- Outer ear shape: tip at (80,2), base from (52,46) to (108,46) -->
            <Polygon Points="52,46 80,2 108,46"
                     Fill="{StaticResource CatPinkBrush}"
                     Stroke="{StaticResource CatWhiskerBrush}"
                     StrokeThickness="1.5"/>
            <!-- Inner ear highlight -->
            <Polygon Points="61,43 80,14 99,43"
                     Fill="#FFCFD8"/>

            <!-- Right ear -->
            <!-- Outer ear shape: tip at (280,2), base from (252,46) to (308,46) -->
            <Polygon Points="252,46 280,2 308,46"
                     Fill="{StaticResource CatPinkBrush}"
                     Stroke="{StaticResource CatWhiskerBrush}"
                     StrokeThickness="1.5"/>
            <!-- Inner ear highlight -->
            <Polygon Points="261,43 280,14 299,43"
                     Fill="#FFCFD8"/>

        </Canvas><!-- /ear overlay -->

    </Grid>
</Window>

