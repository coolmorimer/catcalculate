<Window x:Class="CatCalculate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐱 CatCalculate"
        Width="360"
        Height="620"
        MinWidth="320"
        MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer border provides the rounded window shape -->
    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="24"
            BorderThickness="1.5"
            BorderBrush="{StaticResource CatWhiskerBrush}"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="6"
                              Direction="270" Color="#80806090" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Cat-ear decoration + title bar -->
                <RowDefinition Height="70"/>
                <!-- Display area -->
                <RowDefinition Height="120"/>
                <!-- Thin separator -->
                <RowDefinition Height="12"/>
                <!-- Button grid -->
                <RowDefinition Height="*"/>
                <!-- Paw-print footer -->
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- =======================================================
                 ROW 0 – Title bar with cat ears
                 ======================================================= -->
            <Grid Grid.Row="0">

                <!-- Cat ear – left (drawn with a Canvas+Polygon) -->
                <Canvas Width="52" Height="52"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="30,-2,0,0">
                    <!-- Outer ear shape -->
                    <Polygon Points="0,52  26,0  52,52"
                             Fill="{StaticResource CatPinkBrush}"
                             Stroke="{StaticResource CatWhiskerBrush}"
                             StrokeThickness="1.5"/>
                    <!-- Inner ear (darker pink) -->
                    <Polygon Points="10,48  26,14  42,48"
                             Fill="#FFCFD8"/>
                </Canvas>

                <!-- Cat ear – right -->
                <Canvas Width="52" Height="52"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-2,30,0">
                    <Polygon Points="0,52  26,0  52,52"
                             Fill="{StaticResource CatPinkBrush}"
                             Stroke="{StaticResource CatWhiskerBrush}"
                             StrokeThickness="1.5"/>
                    <Polygon Points="10,48  26,14  42,48"
                             Fill="#FFCFD8"/>
                </Canvas>

                <!-- Title bar background (sits behind the ears) -->
                <Border Background="{StaticResource CatLavenderBrush}"
                        CornerRadius="22,22,0,0"
                        Margin="0,20,0,0"
                        Padding="8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- App title -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="🐱"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="CatCalculate"
                                       Style="{StaticResource TitleTextStyle}"/>
                        </StackPanel>

                        <!-- Close button (small ✕) -->
                        <Button Grid.Column="1"
                                Content="✕"
                                Width="28" Height="28"
                                Margin="0,0,4,0"
                                FontSize="12"
                                Cursor="Hand"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#A080C0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="14">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd"
                                                                Property="Background"
                                                                Value="{StaticResource CatPinkBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- =======================================================
                 ROW 1 – Display area
                 ======================================================= -->
            <Border Grid.Row="1"
                    Background="{StaticResource DisplayGradientBrush}"
                    CornerRadius="16"
                    Margin="16,4,16,4"
                    Padding="16,10"
                    Effect="{StaticResource DisplayShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Expression / history line -->
                    <TextBlock x:Name="ExpressionDisplay"
                               Grid.Row="0"
                               Style="{StaticResource DisplayExpressionStyle}"
                               Text=""/>

                    <!-- Main result / current input -->
                    <TextBlock x:Name="ResultDisplay"
                               Grid.Row="1"
                               Style="{StaticResource DisplayResultStyle}"
                               Text="0"/>
                </Grid>
            </Border>

            <!-- =======================================================
                 ROW 2 – Decorative separator
                 ======================================================= -->
            <Rectangle Grid.Row="2"
                       Style="{StaticResource CatSeparatorStyle}"
                       VerticalAlignment="Center"/>

            <!-- =======================================================
                 ROW 3 – Button grid (5 rows × 4 columns)
                 ======================================================= -->
            <Grid Grid.Row="3" Margin="10,4,10,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: Utility / function row -->
                <!-- C (Clear All) -->
                <Button Grid.Row="0" Grid.Column="0"
                        Content="C"
                        Style="{StaticResource FunctionButtonStyle}"
                        Click="Clear_Click"
                        ToolTip="Clear all"/>

                <!-- CE (Clear Entry) -->
                <Button Grid.Row="0" Grid.Column="1"
                        Content="CE"
                        Style="{StaticResource FunctionButtonStyle}"
                        Click="ClearEntry_Click"
                        ToolTip="Clear current entry"/>

                <!-- ± (Toggle sign) -->
                <Button Grid.Row="0" Grid.Column="2"
                        Content="±"
                        Style="{StaticResource FunctionButtonStyle}"
                        Click="ToggleSign_Click"
                        ToolTip="Toggle positive/negative"/>

                <!-- ⌫ (Backspace) -->
                <Button Grid.Row="0" Grid.Column="3"
                        Content="⌫"
                        Style="{StaticResource FunctionButtonStyle}"
                        Click="Backspace_Click"
                        ToolTip="Delete last digit"/>

                <!-- Row 1 -->
                <!-- % -->
                <Button Grid.Row="1" Grid.Column="0"
                        Content="%"
                        Style="{StaticResource OperatorButtonStyle}"
                        Click="Percent_Click"
                        ToolTip="Percent"/>

                <!-- 7 -->
                <Button Grid.Row="1" Grid.Column="1"
                        Content="7"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="7"/>

                <!-- 8 -->
                <Button Grid.Row="1" Grid.Column="2"
                        Content="8"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="8"/>

                <!-- 9 -->
                <Button Grid.Row="1" Grid.Column="3"
                        Content="9"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="9"/>

                <!-- Row 2 -->
                <!-- ÷ -->
                <Button Grid.Row="2" Grid.Column="0"
                        Content="÷"
                        Style="{StaticResource OperatorButtonStyle}"
                        Click="Operator_Click" Tag="÷"
                        ToolTip="Divide"/>

                <!-- 4 -->
                <Button Grid.Row="2" Grid.Column="1"
                        Content="4"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="4"/>

                <!-- 5 -->
                <Button Grid.Row="2" Grid.Column="2"
                        Content="5"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="5"/>

                <!-- 6 -->
                <Button Grid.Row="2" Grid.Column="3"
                        Content="6"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="6"/>

                <!-- Row 3 -->
                <!-- × -->
                <Button Grid.Row="3" Grid.Column="0"
                        Content="×"
                        Style="{StaticResource OperatorButtonStyle}"
                        Click="Operator_Click" Tag="×"
                        ToolTip="Multiply"/>

                <!-- 1 -->
                <Button Grid.Row="3" Grid.Column="1"
                        Content="1"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="1"/>

                <!-- 2 -->
                <Button Grid.Row="3" Grid.Column="2"
                        Content="2"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="2"/>

                <!-- 3 -->
                <Button Grid.Row="3" Grid.Column="3"
                        Content="3"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="3"/>

                <!-- Row 4 -->
                <!-- − -->
                <Button Grid.Row="4" Grid.Column="0"
                        Content="−"
                        Style="{StaticResource OperatorButtonStyle}"
                        Click="Operator_Click" Tag="−"
                        ToolTip="Subtract"/>

                <!-- 0 (spans 2 columns for the classic wide-zero layout) -->
                <Button Grid.Row="4" Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Content="0"
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Digit_Click" Tag="0"/>

                <!-- . -->
                <Button Grid.Row="4" Grid.Column="3"
                        Content="."
                        Style="{StaticResource NumberButtonStyle}"
                        Click="Decimal_Click"
                        ToolTip="Decimal point"/>

                <!-- + is placed in an overlapping Grid (below) that shares the same
                     Grid.Row="3" slot. The two grids overlap so that + and = span
                     multiple rows in the right-hand column while the digit/operator
                     buttons fill the remaining three columns on the left. -->
            </Grid>

            <!-- Floating right-column: + and = stacked tall, outside the main Grid,
                 positioned absolutely to fill the same visual row band. -->
            <Grid Grid.Row="3" Margin="10,4,10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- + operator (rows 1–2, last column) -->
                <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                        Content="+"
                        Style="{StaticResource OperatorButtonStyle}"
                        Click="Operator_Click" Tag="+"
                        ToolTip="Add"
                        Margin="5"/>

                <!-- = (rows 3–4, last column) — extra tall equals button -->
                <Button Grid.Row="3" Grid.RowSpan="2" Grid.Column="1"
                        Content="="
                        Style="{StaticResource EqualsButtonStyle}"
                        Click="Equals_Click"
                        ToolTip="Calculate"
                        Margin="5"/>
            </Grid>

            <!-- =======================================================
                 ROW 4 – Decorative paw-print footer
                 ======================================================= -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Three small paw prints using the shared PathGeometry -->
                <Viewbox Width="22" Height="22" Margin="6,0">
                    <Path Data="{StaticResource PawPrintGeometry}"
                          Fill="{StaticResource CatPinkBrush}"
                          Opacity="0.6"
                          RenderTransformOrigin="0.5,0.5"/>
                </Viewbox>

                <TextBlock Text="🐾"
                           FontSize="14"
                           Opacity="0.55"
                           VerticalAlignment="Center"
                           Margin="2,0"/>

                <Viewbox Width="22" Height="22" Margin="6,0">
                    <Path Data="{StaticResource PawPrintGeometry}"
                          Fill="{StaticResource CatLavenderDarkBrush}"
                          Opacity="0.6"
                          RenderTransformOrigin="0.5,0.5"/>
                </Viewbox>
            </StackPanel>

        </Grid>
    </Border>
</Window>
